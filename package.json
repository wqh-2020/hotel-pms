{
  "name": "hotel-pms",
  "version": "1.0.0",
  "description": "聚云酒店管理系统",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "node server/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "electron:dev": "concurrently \"npm run dev:server\" \"wait-on http://localhost:3001/api/health && wait-on http://localhost:5173 && electron .\"",
    "electron:build": "cd frontend && npm run build && cd .. && node scripts/copy-server-deps.js && node scripts/copy-node-runtime.js && electron-builder --win"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hotel.pms",
    "productName": "聚云酒店管理系统",
    "files": ["electron/**/*"],
    "extraResources": [
      { "from": "server/",        "to": "server/"        },
      { "from": "_server_deps/",  "to": "node_modules/"  },
      { "from": "frontend/dist/", "to": "frontend/dist/" },
      { "from": "_node_runtime/node.exe", "to": "node.exe" }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
